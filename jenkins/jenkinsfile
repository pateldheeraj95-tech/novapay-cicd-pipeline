pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir('app') {
                    bat 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('app') {
                    bat 'docker build -t novapay-app:latest .'
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                dir('kubernetes') {
                    bat 'kubectl apply -f namespace.yaml'
                    bat 'kubectl apply -f deployment-blue.yaml'
                    bat 'kubectl apply -f service.yaml'
                    bat 'kubectl apply -f ingress.yaml'
                }
            }
        }
    }
}